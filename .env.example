# Salin ke .env lalu isi nilainya (jangan commit .env)
# Password PostgreSQL internal (bebas, acak)
POSTGRES_PASSWORD=ganti-dengan-string-acak
# Secret JWT API mobile (min. 32 karakter): openssl rand -hex 32
JWT_SECRET=ganti-dengan-string-acak-minimal-32-karakter
# URL publik backend yang dipakai browser (di-bake ke bundle frontend saat build)
PUBLIC_API_URL=https://backend-tunnel-anda.trycloudflare.com
PUBLIC_WS_URL=wss://backend-tunnel-anda.trycloudflare.com
