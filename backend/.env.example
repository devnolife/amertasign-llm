# Konfigurasi backend amertasign-llm (prefix AMERTASIGN_)
AMERTASIGN_DEBUG=true
AMERTASIGN_MIN_CONFIDENCE=0.6
AMERTASIGN_JWT_SECRET=ganti-dengan-string-acak-minimal-32-karakter

# CORS origin frontend (JSON list)
# AMERTASIGN_CORS_ORIGINS=["http://localhost:3030"]

# LLM (Fase 5 - tahap kalimat). provider: stub | openai-compatible
AMERTASIGN_LLM_PROVIDER=stub
AMERTASIGN_LLM_BASE_URL=
AMERTASIGN_LLM_API_KEY=
AMERTASIGN_LLM_MODEL=

# Google OAuth Web untuk app Expo. Redirect URI di Google Console:
# <PUBLIC_BASE_URL>/api/v1/auth/google/callback
AMERTASIGN_GOOGLE_CLIENT_IDS=
AMERTASIGN_GOOGLE_CLIENT_SECRET=
AMERTASIGN_PUBLIC_BASE_URL=
